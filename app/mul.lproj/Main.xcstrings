    "TX8-mu-sca.title" : {
      "comment" : "Class = \"NSTextFieldCell\"; title = \"Drop file to use as cover art here.\\nLeave empty to remove existing cover art.\"; ObjectID = \"TX8-mu-sca\"; Note = \"Prompt in cover art dialog\";",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sem přetáhněte soubor pro použití jako obal obalu.\nPonechte prázdné pro odstranění existujícího obálky."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Datei, die hier als Cover verwendet wird.\nLeer lassen, um bestehende Cover zu entfernen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Drop file to use as cover art here.\nLeave empty to remove existing cover art."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Arrastra el archivo para usar como carátula aquí.\nDeje en blanco para eliminar la carátula existente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Déposez un fichier pour l'utiliser comme pochette ici.\nLaissez vide pour supprimer les pochettes existantes."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trascina il file da usare come copertina qui.\nLascia vuoto per rimuovere copertine esistenti."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "여기에 커버 아트로 사용할 파일을 놓으십시오.\n기존 커버 아트를 제거하려면 비워 두십시오."
          }
        },
        "nb-NO" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Slipp filen som omslagsbilde her.\nLa stå tom for å fjerne eksisterende forside-kunst."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sleep het bestand hier naartoe om de hoesafbeeldingen te gebruiken.\nLaat leeg om bestaande hoesafbeeldingen te verwijderen."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Arraste aqui o arquivo para usar como capa.\nDeixe vazio para remover a capa existente."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Largue aqui o ficheiro a usar como capa.\nDeixe em branco para remover a capa existente."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Перетащите файл сюда, чтобы использовать его в качестве обложки.\nОставьте пустым, чтобы удалить текущую обложку."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Släpp filen för att använda som omslagsbild här.\nLämna tomt för att ta bort befintlig omslagsbild."
          }
        }
      }
    },
