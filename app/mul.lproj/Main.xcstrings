    "QE0-Cv-OSp.title" : {
      "comment" : "Class = \"NSTextFieldCell\"; title = \"To see thumbnails of video files you may need to relaunch Finder or log out and back in again.\"; ObjectID = \"QE0-Cv-OSp\"; Note = \"Advice\";",
      "localizations" : {
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Per veure les previsualitzacions dels fitxers de video hauries de recarregar el Finder o tancar la sessió i tornar a entrar."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pro zobrazení náhledů video souborů je potřeba restartovat Finder nebo se odhlásit a přihlásit zpět."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bitte starten Sie Finder neu oder melden Sie sich erneut an, um die Vorschau von Videodateien zu sehen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Για να δείτε μικρογραφίες στα αρχεία βίντεο μπορεί να χρειαστεί να επανεκκινήσετε τον Finder ή να πραγματοποιήσετε έξοδο και επανείσοδο στο σύστημα."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "To see thumbnails of video files you may need to relaunch Finder or log out and back in again."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para ver las vistas en miniatura de los archivos de video es posible que necesites reiniciar el Finder, o cerrar sesión y reingresar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pour voir les vignettes des fichiers vidéo, vous devez relancer le Finder ou vous déconnecter puis vous reconnecter."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ahhoz hogy a videó fájlok bélyegképei láthatóak legyenek újra kell indítani a Findert, vagy ki és be kell jelentkezni."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Per visualizzare le miniature dei file video potrebbe essere necessario rilanciare il Finder o uscire e rientrare di nuovo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ムービーのサムネイルが表示されない場合は、Finderを再起動するか、一旦システムからログアウトして再度ログインしてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "동영상 파일의 썸네일을 보기 위해서는 Finder를 재실행하거나 로그아웃 후 다시 로그인해야 합니다."
          }
        },
        "nb-NO" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "For å se miniatyrbilder av videofiler så trenger du i noen tilfeller å starte Finder på nytt. Du kan og logge ut og inn igjen."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Herstart Finder of log opnieuw in om de voorvertoning van videobestanden te zien."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para ver miniaturas dos vídeos você precisa reiniciar o Finder ou finalizar sessão e iniciar novamente."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Para ver as miniaturas de ficheiros de vídeo, poderá ter de reiniciar o Finder ou terminar a sua sessão e iniciar novamente."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Чтобы увидеть миниатюры файлов, вам может потребоваться перезапустить Finder или перезагрузить систему."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "För att se miniatyrer av videofiler så behöver du i vissa dall starta om Finder. Du kan också logga ut och logga in igen."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您可能需要重新启动Finder或登出账户并重新登录以显示视频缩略图。"
          }
        }
      }
    },
