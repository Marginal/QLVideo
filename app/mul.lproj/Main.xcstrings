    "wBi-TN-rGU.title" : {
      "comment" : "Class = \"NSTextFieldCell\"; title = \"You may experience high CPU and disk usage for the next few minutes while Spotlight re-indexes all of your “non-native” audio and video files.\"; ObjectID = \"wBi-TN-rGU\"; Note = \"Advice\";",
      "localizations" : {
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pots experimentar un increment d'utilització de CPU i d'accés al disc per uns minuts, mentre el Spotlight torna a re-indexar tots els teus arxius de video i audio “no-nadius”."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Po několik následujících minut můžete pociťovat zvýšenou práci procesoru a využití disku z důvodu re-indexace Spotlight pro všechny Vaše \"nenativní\" audio a video soubory."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "In den nächsten Minuten kann es zu einer erhöhten Prozessor- und Festplattenauslastung kommen, da Spotlight zunächst alle nicht-unterstützten Audio- und Videodateien indexiert."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ενδέχεται να αντιμετωπίσετε υψηλή χρήση CPU και δίσκου για τα επόμενα λίγα λεπτά, καθώς το Spotlight επανευρετηριάζει όλα τα “μη-εγγενή” αρχεία ήχου και βίντεο."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You may experience high CPU and disk usage for the next few minutes while Spotlight re-indexes all of your “non-native” audio and video files."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Es posible que experimentes un alto uso del CPU y disco durante algunos minutos mientras Spotlight reindexa todos tus archivos de audio y video “no nativos”."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous pouvez rencontrer une forte activité du processeur et du disque dur pendant quelques minutes, le temps que Spotlight ré-indexe tous vos fichiers vidéos et audio «non natifs»."
          }
        },
        "hu" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Magas CPU és lemezhasználat tapasztalható a következő pár percben, ameddig a Spotlight újraindexeli az összes \"nem natív\" audió és videó fájlt."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si può verificare unʼelevata attività del processore e del disco rigido per qualche minuto il tempo che Spotlight re-indicizza i tuoi file video e audio «non nativo»."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spotlightが、標準でサポートされない音声・動画ファイル全てのインデックスを再作成するため、今後数分間、CPUやディスクの使用率が高まる場合があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spotlight이 시스템이 기본 지원하지 않는 오디오와 비디오 파일의 색인을 재작성하는 동안 CPU와 디스크 사용량이 몇 분간 높아질 수 있습니다."
          }
        },
        "nb-NO" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du kan oppleve høy CPU- og diskbruk noen minutter etter installasjonen. Dette er fordi Spotlight re-indexerer alle lyd- og videofilene som tidligere ikke var tilgjengelig i Mac OS X."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "In de komende minuten kan uw processor- en schijfactiviteit sterk toenemen, omdat Spotlight eerst alle niet-ondersteunde audio- en videobestanden indexeert."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você poderá perceber um alto uso da CPU e do disco nos próximos minutos enquanto a Spotlight indexa todos os arquivos de áudio e vídeo “não-nativos”."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Poderá reparar num uso elevado do CPU e disco nos próximos minutos, enquanto o Spotlight reindexa todos os seus arquivos de áudio e vídeo não nativos ao macOS."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "В течение следующих нескольких минут процессор и диск могут быть загружены, пока Spotlight переиндексирует все ваши «неродные» аудио и видео файлы."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du kan uppleva hög CPU- och diskanvändning några minuter efter installationen. Detta beror på att Spotlight omindexerar alla dina video- och audiofiler som på förhand ej stöds av Mac OS X."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此后几分钟您的CPU和硬盘可能会出现高负荷，因为Spotlight需要重新检索您的所有非默认支持的音频和视频文件。"
          }
        }
      }
    },
