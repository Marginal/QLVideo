    "Ao2-4O-GKj.ibShadowedToolTip" : {
      "comment" : "Class = \"NSSlider\"; ibShadowedToolTip = \"The time at which to take a snapshot for thumbnails in Finder windows.\\nOnly for files that don't contain cover art.\"; ObjectID = \"Ao2-4O-GKj\"; Note = \"Tooltip for snapshot time slider\";",
      "extractionState" : "stale",
      "localizations" : {
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Doba, ve které je potřeba zabrat snímek náhledů v oknech Finder.\nPouze pro soubory, které neobsahují potahový art."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Zeit, zu der ein Schnappschuss für Miniaturen im Finder-Fenster gemacht werden soll.\nNur für Dateien, die keine Cover-Art enthalten."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "The time at which to take a snapshot for thumbnails in Finder windows.\nOnly for files that don't contain cover art."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El tiempo en el que tomar una instantánea para las miniaturas en las ventanas del Buscador.\nSolo para los archivos que no contienen arte de cubierta."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'heure à laquelle prendre un instantané pour les vignettes dans les fenêtres du Finder.\nSeulement pour les fichiers qui ne contiennent pas de pochette."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il momento in cui scattare un'istantanea per le miniature nelle finestre di Finder.\nSolo per i file che non contengono copertine."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "파인더에서 썸네일을 표시하기 위해 스냅샷을 찍은 시간입니다. 앨범 커버가 없는 파일에만 적용됩니다."
          }
        },
        "nb-NO" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tid for å ta et øyeblikksbilde for miniatyrbilder i Finder-vinduer.\nBare for filer som ikke inneholder forsidesteg."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De tijd om een momentopname te maken voor miniaturen in Findervensters.\nAlleen voor bestanden die geen omslagkunst bevatten."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O tempo no qual tirar um snapshot para miniaturas nas janelas do Finder.\napenas para arquivos que não contêm arte."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O tempo no qual tirar um snapshot para miniaturas nas janelas do Finder.\napenas para arquivos que não contêm arte."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Время, в которое будет сделан снимок для миниатюр в окнах Finder.\nТолько для файлов, не имеющих обложки."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tiden för att ta en ögonblicksbild för miniatyrer i Finder fönster.\nEndast för filer som inte innehåller omslagskonst."
          }
        }
      }
    },
