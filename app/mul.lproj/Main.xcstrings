    "OoJ-wE-2Cu.title" : {
      "comment" : "Class = \"NSTextFieldCell\"; title = \"There are some recent crash reports for this app's plugins \"; ObjectID = \"OoJ-wE-2Cu\"; Note = \"Crash reports dialog\";",
