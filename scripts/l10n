#!/bin/sh
#
# Deal with uploading and downloading files to Crowdin
# Run from project root.
#

set -e

case ".$1" in
    .upload)
        # Zip all localized .strings files except source language English.
        rm -f upload.zip
        zip upload.zip */*.lproj/*.strings -x "*/en.lproj/*"
        ;;

    .download)
        # Put downloaded .strings files in the correct places
        translations_dir="QuickLook Video (translations)"
        if [ ! -d "$translations_dir" ]; then
            echo "Translations directory not found: $translations_dir" >&2
            exit 1
        fi

        normalize() {
            case "$1" in
                es-ES) echo "es" ;;
                sv-SE) echo "sv" ;;
                zh-CN) echo "zh-Hans" ;;
                *) echo "$1" ;;
            esac
        }

        for lang_dir in "$translations_dir"/*; do
            lang=$(basename "$lang_dir")
            lang=$(normalize "$lang")
            cp "${lang_dir}/Main.strings" "app/${lang}.lproj/"
            cp "${lang_dir}/schema.strings" "mdimporter/${lang}.lproj/"
        done
        
        rm -rf "QuickLook Video (translations)"

        # ensure buildstrings is invoked
        touch app/Base.lproj/Main.xib
        ;;

    *)
        echo "Usage: $0 upload|download" >&2
        exit 1
        ;;
esac
